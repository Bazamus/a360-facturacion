              "value": "return=representation"
            }
          ]
        },
        "options": {
          "response": { "response": { "neverError": true } }
        }
      },
      "id": "patch-estado-supabase",
      "name": "Actualizar Estado Supabase",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [840, -80],
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {},
      "id": "noop-no-relevante",
      "name": "Sin Acción",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
      "position": [840, 120]
    }
  ],
  "connections": {
    "Webhook Chatwoot": {
      "main": [
        [{ "node": "Extraer Evento", "type": "main", "index": 0 }]
      ]
    },
    "Extraer Evento": {
      "main": [
        [{ "node": "Es Relevante?", "type": "main", "index": 0 }]
      ]
    },
    "Es Relevante?": {
      "main": [
        [{ "node": "Actualizar Estado Supabase", "type": "main", "index": 0 }],
        [{ "node": "Sin Acción", "type": "main", "index": 0 }]
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "meta": {
    "description": "Recibe webhooks de Chatwoot y sincroniza el estado de las comunicaciones en Supabase.\n\nEventos manejados:\n- conversation_status_changed + status=resolved → estado='respondido'\n- conversation_deleted → estado='archivado'\n\nConfigurar en Chatwoot: Settings → Integrations → Webhooks → Add New\nURL: https://<tu-n8n>/webhook/chatwoot-sync\nEvents: conversation_status_changed, conversation_deleted"
  }
}
