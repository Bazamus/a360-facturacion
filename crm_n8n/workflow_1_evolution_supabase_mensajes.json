      "id": "webhook-trigger",
      "name": "Webhook Evolution",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [0, 0],
      "webhookId": "evolution-messages",
      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const raw = item.json;\n  const body = raw.body || raw;\n  const event = body.event || '';\n  const data = body.data || {};\n\n  const eventosValidos = ['messages.upsert', 'send.message', 'messages.update'];\n  if (!eventosValidos.includes(event)) {\n    results.push({ json: { skip: true, event: event || 'desconocido' } });\n    continue;\n  }\n\n  if (event === 'messages.update') {\n    const updates = Array.isArray(data) ? data : [data];\n    const update = updates[0] || {};\n    const key = update.key || {};\n    const status = update.update ? update.update.status : null;\n\n    let estadoNuevo = null;\n    if (status === 3) estadoNuevo = 'entregado';\n    else if (status === 4) estadoNuevo = 'leido';\n    else if (status === 5) estadoNuevo = 'leido';\n\n    results.push({\n      json: {\n        tipo_evento: 'update',\n        external_id: key.id || '',\n        estado_nuevo: estadoNuevo,\n        skip: !estadoNuevo\n      }\n    });\n    continue;\n  }\n\n  const key = data.key || {};\n  const message = data.message || {};\n  const pushName = data.pushName || '';\n\n  let contenido = '';\n  let contenido_tipo = 'texto';\n\n  if (message.conversation) {\n    contenido = message.conversation;\n  } else if (message.extendedTextMessage && message.extendedTextMessage.text) {\n    contenido = message.extendedTextMessage.text;\n  } else if (message.imageMessage) {\n    contenido = message.imageMessage.caption || '[Imagen]';\n    contenido_tipo = 'imagen';\n  } else if (message.audioMessage) {\n    contenido = '[Audio]';\n    contenido_tipo = 'audio';\n  } else if (message.videoMessage) {\n    contenido = message.videoMessage.caption || '[Video]';\n    contenido_tipo = 'video';\n  } else if (message.documentMessage) {\n    contenido = message.documentMessage.fileName || '[Documento]';\n    contenido_tipo = 'documento';\n  } else if (message.locationMessage) {\n    contenido = '[Ubicacion: ' + message.locationMessage.degreesLatitude + ', ' + message.locationMessage.degreesLongitude + ']';\n    contenido_tipo = 'ubicacion';\n  } else {\n    contenido = '[Mensaje no soportado]';\n  }\n\n  const fromMe = key.fromMe === true;\n  const direccion = fromMe ? 'saliente' : 'entrante';\n\n  const remoteJid = key.remoteJid || '';\n  const telefono = remoteJid.replace('@s.whatsapp.net', '').replace('@g.us', '');\n\n  if (remoteJid.indexOf('@g.us') !== -1) {\n    results.push({ json: { skip: true, motivo: 'mensaje_grupo' } });\n    continue;\n  }\n\n  results.push({\n    json: {\n      tipo_evento: 'mensaje',\n      skip: false,\n      telefono: telefono,\n      contenido: contenido,\n      contenido_tipo: contenido_tipo,\n      direccion: direccion,\n      external_id: key.id || '',\n      remitente_nombre: pushName,\n      estado: fromMe ? 'enviado' : 'recibido'\n    }\n  });\n}\n\nreturn results;"
      },
