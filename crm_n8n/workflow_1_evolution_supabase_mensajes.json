    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Solo extraccion de datos - sin llamadas HTTP\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const convsData = item.json;\n  const conversations = convsData.payload || [];\n\n  if (!Array.isArray(conversations) || !conversations.length) {\n    results.push({ json: { skip: true, motivo: 'sin_conversaciones' } });\n    continue;\n  }\n\n  // Tomar la conversacion con ID mas alto (la mas reciente)\n  const latestConv = conversations.reduce(\n    (max, c) => (c.id > max.id ? c : max),\n    conversations[0]\n  );\n\n  // Obtener el ID del registro insertado en Supabase desde el nodo INSERT\n  const insertResp = $('INSERT Comunicacion').item.json;\n  const recordId = Array.isArray(insertResp) ? insertResp[0]?.id : insertResp?.id;\n\n  results.push({\n    json: {\n      skip: false,\n      chatwoot_conversation_id: String(latestConv.id),\n      record_id: recordId\n    }\n  });\n}\n\nreturn results;"
      },
