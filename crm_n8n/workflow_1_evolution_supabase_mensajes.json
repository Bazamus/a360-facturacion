    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Solo extraccion de datos - sin llamadas HTTP\nconst items = $input.all();\nconst results = [];\n\nfor (const item of items) {\n  const searchData = item.json;\n  // Chatwoot v3 devuelve payload como array, versiones anteriores como { contacts: [...] }\n  const contacts = searchData.payload?.contacts\n    || (Array.isArray(searchData.payload) ? searchData.payload : [])\n    || [];\n\n  if (!contacts.length) {\n    results.push({ json: { skip: true, motivo: 'contacto_no_encontrado' } });\n    continue;\n  }\n\n  results.push({ json: { skip: false, contact_id: contacts[0].id } });\n}\n\nreturn results;"
      },
