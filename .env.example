# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ============================================
# RESEND EMAIL SERVICE
# ============================================
# API Key de Resend para envío de emails
# Obtener en: https://resend.com/api-keys
# IMPORTANTE: Configurar en Vercel Dashboard, NO en .env.local
VITE_RESEND_API_KEY=your_resend_api_key_here

# Secret del webhook de Resend (comienza con whsec_)
# Configurar en: https://resend.com/webhooks
# IMPORTANTE: Configurar en Vercel Dashboard, NO en .env.local
VITE_RESEND_WEBHOOK_SECRET=your_webhook_secret_here

# Email remitente verificado en Resend
# Debe coincidir con el dominio verificado (a360se.com)
VITE_FROM_EMAIL=facturacion@a360se.com

# URL base de la aplicación (para emails y assets públicos)
# En producción: https://tu-app.vercel.app
# En desarrollo: http://localhost:5173
VITE_APP_URL=http://localhost:5173
